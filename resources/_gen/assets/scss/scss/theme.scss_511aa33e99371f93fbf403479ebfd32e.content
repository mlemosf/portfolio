*{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,segoe ui,sans-serif;background:#f8fafc;color:#0f172a;line-height:1.65}img{max-width:100%;display:block}a{color:#14b8a6;text-decoration:none}a:hover,a:focus{text-decoration:underline}h1,h2,h3,p{margin-top:0}h1,h2,h3{line-height:1.15}ul{margin:0;padding:0}.site-main{width:100%;max-width:1080px;margin:0 auto;padding:0 1rem}.section{padding:4rem 0}.section__inner{width:100%}.section__kicker{color:#14b8a6;font-size:.85rem;font-weight:800;letter-spacing:.12em;margin-bottom:.5rem;text-transform:uppercase}.section h2{font-size:clamp(2rem,4vw,3rem);margin-bottom:2rem}.site-main{width:100%;max-width:1080px;margin:0 auto;padding:0 1rem}.section{padding:4rem 0}.section__inner{width:100%}.section__kicker{color:#14b8a6;font-size:.85rem;font-weight:800;letter-spacing:.12em;margin-bottom:.5rem;text-transform:uppercase}.section h2{font-size:clamp(2rem,4vw,3rem);margin-bottom:2rem}.site-header{background:radial-gradient(circle at top left,rgba(20,184,166,.35),transparent 35%),linear-gradient(135deg,#0f172a,#1e293b);color:#fff;padding:5rem 1rem 4rem;text-align:center}.site-header__content{margin:0 auto;max-width:760px}.profile-pic{width:168px;height:168px;border-radius:999px;object-fit:cover;border:5px solid rgba(255,255,255,.92);box-shadow:0 20px 40px rgba(0,0,0,.25);margin:0 auto 1.5rem;background:#ccfbf1}.eyebrow{color:#ccfbf1;font-size:.85rem;font-weight:800;letter-spacing:.14em;margin-bottom:.75rem;text-transform:uppercase}.site-header h1{font-size:clamp(2.5rem,8vw,5rem);margin-bottom:.5rem}.site-role{color:#ccfbf1;font-size:clamp(1.2rem,2.5vw,1.6rem);font-weight:700;margin-bottom:1rem}.site-description{color:rgba(255,255,255,.82);font-size:1.05rem;margin:0 auto;max-width:620px}.timeline{position:relative;display:grid;gap:1.5rem;margin-top:2rem}.timeline::before{content:"";position:absolute;bottom:0;left:.55rem;top:.75rem;width:2px;background:linear-gradient(#14b8a6,rgba(20,184,166,8%))}.timeline-item{display:grid;grid-template-columns:1.4rem 1fr;gap:1rem;position:relative}.marker{width:1.1rem;height:1.1rem;border-radius:999px;background:#14b8a6;border:3px solid #f8fafc;box-shadow:0 0 0 4px #ccfbf1;margin-top:1.25rem;position:relative;z-index:1}.timeline-card{background:#fff;border:1px solid #e2e8f0;border-radius:1.25rem;box-shadow:0 18px 45px rgba(15,23,42,8%);padding:1.5rem}.timeline-date{color:#14b8a6;font-size:.9rem;font-weight:800;margin-bottom:.5rem}.timeline-card h3{font-size:1.4rem;margin-bottom:.5rem}.timeline-card h3 span{color:#64748b;font-weight:600}.timeline-location{color:#64748b;font-weight:700;margin-bottom:.75rem}.tech-stack{display:flex;flex-wrap:wrap;gap:.5rem;list-style:none;margin-top:1rem}.tech-stack li{background:#ccfbf1;border-radius:999px;color:#115e59;font-size:.85rem;font-weight:800;padding:.35rem .75rem}.testimonials{display:grid;gap:1.25rem;grid-template-columns:repeat(auto-fit,minmax(260px,1fr))}.testimonial{background:#fff;border:1px solid #e2e8f0;border-radius:1.25rem;box-shadow:0 18px 45px rgba(15,23,42,8%);margin:0;padding:1.5rem}.testimonial__avatar{width:56px;height:56px;border-radius:999px;object-fit:cover;margin-bottom:1rem}.testimonial blockquote{color:#1e293b;font-size:1.05rem;margin:0 0 1.25rem}.testimonial figcaption{display:grid;gap:.15rem}.testimonial .author{font-weight:900}.testimonial .role{color:#64748b;font-size:.9rem}.databricks{background:linear-gradient(180deg,#ffffff 0%,#f8fafc 100%)}.databricks .section__intro{color:#64748b;font-size:1.125rem;max-width:600px;margin-bottom:3rem}.feature-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1.5rem;margin-top:2rem}.feature-card{background:#fff;border-radius:1.25rem;padding:1.75rem;border:1px solid #e2e8f0;box-shadow:0 18px 45px rgba(15,23,42,8%);transition:transform .2s ease,box-shadow .2s ease;display:flex;flex-direction:column;height:100%}.feature-card:hover{transform:translateY(-4px);box-shadow:0 24px 60px rgba(15,23,42,.12)}.feature-card__header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:1.25rem}.feature-card__icon{width:3.5rem;height:3.5rem;background:linear-gradient(135deg,#ccfbf1 0%,#14b8a6 100%);border-radius:1rem;display:flex;align-items:center;justify-content:center;color:#fff}.feature-card__icon svg{width:1.75rem;height:1.75rem}.feature-card__status{font-size:.75rem;font-weight:600;padding:.375rem .75rem;border-radius:2rem;text-transform:uppercase;letter-spacing:.05em}.feature-card__status--completed{background:#dcfce7;color:#166534}.feature-card__status--in-progress{background:#fef3c7;color:#92400e}.feature-card__status--ongoing{background:#dbeafe;color:#1e40af}.feature-card__category{color:#14b8a6;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;margin-bottom:.5rem}.feature-card__title{font-size:1.375rem;font-weight:700;color:#0f172a;margin-bottom:.75rem;line-height:1.3}.feature-card__summary{color:#64748b;font-size:.95rem;line-height:1.6;margin-bottom:1.5rem;flex-grow:1}.feature-card__tags{margin-top:auto;padding-top:1.25rem;border-top:1px solid #e2e8f0}.tag-group{margin-bottom:1rem}.tag-group:last-child{margin-bottom:0}.tag-group__label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#64748b;display:block;margin-bottom:.5rem}.tag-list{display:flex;flex-wrap:wrap;gap:.5rem;list-style:none;margin:0;padding:0}.tag{font-size:.8rem;font-weight:600;padding:.375rem .75rem;border-radius:.5rem;white-space:nowrap}.tag--aws{background:#fff7ed;color:#c2410c;border:1px solid #fed7aa}.tag--databricks{background:#ccfbf1;color:#0f766e;border:1px solid #99f6e4}.empty-state{text-align:center;padding:3rem;color:#64748b;font-style:italic}@media(max-width:768px){.feature-grid{grid-template-columns:1fr;gap:1.25rem}.feature-card{padding:1.5rem}.feature-card__icon{width:3rem;height:3rem}.feature-card__icon svg{width:1.5rem;height:1.5rem}}.site-footer{background:#0f172a;color:rgba(255,255,255,.82);margin-top:2rem;padding:2rem 1rem}.site-footer__inner{align-items:center;display:flex;gap:1rem;justify-content:space-between;margin:0 auto;max-width:1080px}.footer-contact{margin:0}.social-links{display:flex;gap:.75rem;list-style:none}.social-links a{align-items:center;background:rgba(255,255,255,.1);border-radius:999px;display:inline-flex;height:42px;justify-content:center;transition:background 160ms ease,transform 160ms ease;width:42px}.social-links a:hover,.social-links a:focus{background:rgba(20,184,166,.25);transform:translateY(-2px)}.social-links img{height:21px;width:21px}@media(max-width:640px){.site-footer__inner{align-items:flex-start;flex-direction:column}}